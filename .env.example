# ===========================================
# SD Learning Platform - 環境變數範例
# ===========================================

# 基本設定
PROJECT_NAME=SD Learning Platform
VERSION=0.1.0

# 安全設定 (生產環境請更換)
SECRET_KEY=your-super-secret-key-change-in-production

# 資料庫設定
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sd_learning

# Redis 設定
REDIS_URL=redis://localhost:6379/0

# MinIO 物件儲存設定
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=sd-learning

# Google OAuth 設定
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SendGrid 郵件設定 (可選)
SENDGRID_API_KEY=your-sendgrid-api-key

# OpenAI API 設定 (AI 審核用)
OPENAI_API_KEY=your-openai-api-key

# ECPay 金流設定
ECPAY_MERCHANT_ID=your-merchant-id
ECPAY_HASH_KEY=your-hash-key
ECPAY_HASH_IV=your-hash-iv

# 前端設定
NEXT_PUBLIC_API_URL=http://localhost:8000
